# Copy to .env.local for local development. Never commit .env.local.
# Set the same variables in Vercel → Project → Settings → Environment Variables.

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Maps (Cloud Console → APIs & Services → Credentials)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_browser_maps_key
# Optional server-only key for Places / Directions (recommended)
GOOGLE_MAPS_SERVER_API_KEY=your_server_maps_key

# City Run admin panel
CITY_RUN_ADMIN_USERNAME=your_admin_username
CITY_RUN_ADMIN_PASSWORD=your_strong_admin_password
CITY_RUN_ADMIN_SESSION_SECRET=generate_with_openssl_rand_hex_32

# Rider session signing (openssl rand -hex 32)
CITY_RUN_RIDER_SESSION_SECRET=generate_with_openssl_rand_hex_32

# App URL (production)
NEXT_PUBLIC_APP_URL=https://www.citygateshl.org

# Web push (optional — generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@citygateshl.com

# Firebase (optional)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
